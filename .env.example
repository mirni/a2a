# =============================================================================
# A2A Commerce Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
#
# PRE-FLIGHT CHECKLIST:
#   1. [ ] STRIPE_API_KEY — get from https://dashboard.stripe.com/apikeys
#   2. [ ] STRIPE_WEBHOOK_SECRET — get from Stripe webhook settings
#   3. [ ] GITHUB_TOKEN — create at https://github.com/settings/tokens
#   4. [ ] A2A_DATA_DIR — create directory and set permissions (writable by app)
#   5. [ ] AUDITOR_PRIVATE_KEY / AUDITOR_PUBLIC_KEY — generate Ed25519 keypair
#          python -c "from cryptography.hazmat.primitives.asymmetric.ed25519 import Ed25519PrivateKey; \
#            from cryptography.hazmat.primitives import serialization; \
#            k = Ed25519PrivateKey.generate(); \
#            print('PRIVATE:', k.private_bytes(serialization.Encoding.Raw, serialization.PrivateFormat.Raw, serialization.NoEncryption()).hex()); \
#            print('PUBLIC:', k.public_key().public_bytes(serialization.Encoding.Raw, serialization.PublicFormat.Raw).hex())"
#   6. [ ] PostgreSQL connector — set PG_* variables if using database tools
#   7. [ ] Review CORS_ALLOWED_ORIGINS for your deployment domain
#   8. [ ] Review METRICS_ALLOWED_IPS for monitoring access
# =============================================================================

# =============================================================================
# SERVER (REQUIRED)
# =============================================================================

# Bind address and port
HOST=0.0.0.0
PORT=8000

# Data directory for SQLite databases (REQUIRED — must exist and be writable)
A2A_DATA_DIR=/var/lib/a2a

# Public base URL / domain (used for Stripe checkout callbacks)
# A2A_BASE_URL=https://api.greenhelix.net
# A2A_DOMAIN=api.greenhelix.net

# --- Formal Gatekeeper — AWS Lambda Z3 backend ---
# See docs/infra/AWS_Z3_VERIFIER_SETUP.md for details
VERIFIER_LAMBDA_FUNCTION=z3-verifier
VERIFIER_LAMBDA_REGION=us-east-1
VERIFIER_AUTH_MODE=iam

# Credentials for the a2a-gateway-verifier IAM user
AWS_ACCESS_KEY_ID=AKIA...         # from deploy output
AWS_SECRET_ACCESS_KEY=...         # from deploy output
AWS_REGION=us-east-1

# =============================================================================
# STRIPE (REQUIRED for payment processing)
# =============================================================================

# Stripe secret key — get from https://dashboard.stripe.com/apikeys
# Permissions: charges, payment intents, checkout sessions, customers
# Use sk_test_* for development, sk_live_* for production
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here

# Stripe webhook signing secret — get from Stripe webhook endpoint settings
# Required to verify webhook signatures (prevents spoofed events)
# Create webhook at: https://dashboard.stripe.com/webhooks
# Events needed: checkout.session.completed
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# =============================================================================
# GITHUB CONNECTOR (REQUIRED for GitHub tools)
# =============================================================================

# GitHub personal access token (classic or fine-grained)
# Create at: https://github.com/settings/tokens
# Required permissions (fine-grained):
#   - Repository access: select repos you want to expose
#   - Contents: Read-only          (get_file_contents, list_commits)
#   - Issues: Read and write       (list_issues, create_issue)
#   - Pull requests: Read and write (list/get/create_pull_request)
#   - Metadata: Read-only          (list_repos, get_repo, search_code)
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# =============================================================================
# POSTGRESQL CONNECTOR (optional — for database query tools)
# =============================================================================
# This is a fully implemented MCP server (products/connectors/postgres/) that
# lets AI agents safely query a PostgreSQL database. Read-only by default,
# uses parameterized queries only, with SQL injection prevention.
#
# Set these to YOUR actual database credentials. The values below are
# placeholders — they won't connect to anything.
# Tests require a live PostgreSQL instance and are skipped in CI.

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=your_database_user
PG_PASSWORD=your_database_password
PG_SSL=false
PG_READ_ONLY=true

# =============================================================================
# IDENTITY / ATTESTATION KEYS (REQUIRED for identity product)
# =============================================================================
# Ed25519 keypair used to sign and verify identity attestations.
# Generate with the command in the pre-flight checklist above.

AUDITOR_PRIVATE_KEY=your_ed25519_private_key_hex
AUDITOR_PUBLIC_KEY=your_ed25519_public_key_hex

# =============================================================================
# DATABASE DSNs
# =============================================================================
# All default to in-memory SQLite if not set. For production, use file paths.
# Format: sqlite:////absolute/path/to/file.db
# For PostgreSQL: postgresql://user:pass@host:port/dbname

BILLING_DSN=sqlite:////var/lib/a2a/billing.db
PAYWALL_DSN=sqlite:////var/lib/a2a/paywall.db
PAYMENTS_DSN=sqlite:////var/lib/a2a/payments.db
MARKETPLACE_DSN=sqlite:////var/lib/a2a/marketplace.db
TRUST_DSN=sqlite:////var/lib/a2a/trust.db
EVENT_BUS_DSN=sqlite:////var/lib/a2a/events.db
WEBHOOK_DSN=sqlite:////var/lib/a2a/webhooks.db
IDENTITY_DSN=sqlite:////var/lib/a2a/identity.db
MESSAGING_DSN=sqlite:////var/lib/a2a/messaging.db
DISPUTE_DSN=sqlite:////var/lib/a2a/disputes.db

# =============================================================================
# SECURITY & ACCESS CONTROL
# =============================================================================

# Webhook payload encryption key (optional — encrypts webhook secrets at rest)
# WEBHOOK_ENCRYPTION_KEY=your_fernet_key_here

# systemd credentials directory (optional — for secret injection via systemd)
# CREDENTIALS_DIRECTORY=/run/credentials/a2a-gateway

# IP allowlist for /v1/metrics endpoint (comma-separated, optional)
# METRICS_ALLOWED_IPS=127.0.0.1,10.0.0.0/8

# CORS allowed origins (comma-separated; default: *)
# CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# =============================================================================
# GATEWAY TUNING (optional — sensible defaults provided)
# =============================================================================

# Maximum items per batch request (default: 10)
# A2A_MAX_BATCH_SIZE=10

# Credits per dollar (default: 100)
# A2A_CREDITS_PER_DOLLAR=100

# Minimum credits per purchase (default: 100)
# A2A_MIN_CREDITS=100

# Maximum credits per transaction (default: 1000000)
# A2A_MAX_CREDITS=1000000

# Webhook delivery: max retry attempts (default: 3)
# A2A_WEBHOOK_MAX_ATTEMPTS=3

# Webhook delivery: timeout in seconds (default: 10.0)
# A2A_WEBHOOK_TIMEOUT=10.0

# MCP connector process timeout in seconds (default: 30.0)
# A2A_MCP_TIMEOUT=30.0

# Health check interval in seconds (default: 300)
# A2A_HEALTH_INTERVAL=300

# Subscription scheduler interval in seconds (default: 300)
# A2A_SCHEDULER_INTERVAL=300

# =============================================================================
# PAYWALL / TIER CONFIGURATION
# =============================================================================

# Default tier for new agents (free, pro, enterprise)
DEFAULT_TIER=free

# =============================================================================
# REPUTATION PIPELINE (optional — for trust/reputation scoring)
# =============================================================================

# How often to run probe cycles (seconds)
PROBE_INTERVAL=300

# How often to run security scans (seconds)
SCAN_INTERVAL=3600

# Pipeline cycle interval (seconds)
PIPELINE_CYCLE=60

# HTTP timeout for probes (seconds)
PROBE_TIMEOUT=10

# =============================================================================
# LOGGING
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO

# =============================================================================
# x402 PROTOCOL (optional — internet-native crypto payments)
# =============================================================================

# Enable x402 payment fallback when no API key is present
X402_ENABLED=false

# Your merchant wallet address (receives USDC payments)
X402_MERCHANT_ADDRESS=0xYourWalletAddressHere

# Coinbase x402 Facilitator URL
X402_FACILITATOR_URL=https://x402.org/facilitator

# Comma-separated supported networks (base, polygon)
X402_SUPPORTED_NETWORKS=base,polygon

# =============================================================================
# LEGACY (deprecated — will be removed)
# =============================================================================

# Enable legacy /execute endpoint (default: disabled)
# A2A_LEGACY_EXECUTE=false
