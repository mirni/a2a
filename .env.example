# =============================================================================
# A2A Commerce Platform — Environment Configuration
# =============================================================================
# Copy this file to .env and fill in your values.
# Only the variables marked REQUIRED must be set.
# All database paths default to in-memory SQLite if not set.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
HOST=0.0.0.0
PORT=8000

# --- Data directory (SQLite databases stored here) ---
A2A_DATA_DIR=/var/lib/a2a

# -----------------------------------------------------------------------------
# Connector API Keys
# -----------------------------------------------------------------------------

# Stripe connector (REQUIRED to use Stripe tools)
STRIPE_API_KEY=sk_test_your_stripe_secret_key_here

# GitHub connector (REQUIRED to use GitHub tools)
# Should be a short-lived token with the following permissions:
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ list_repos          │ GET         │ (any token — lists what you can see)               │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ get_repo            │ GET         │ repo for private, none for public                  │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ list_issues         │ GET         │ repo for private                                   │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ create_issue        │ POST        │ repo (write)                                       │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ list_pull_requests  │ GET         │ repo for private                                   │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ get_pull_request    │ GET         │ repo for private                                   │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ create_pull_request │ POST        │ repo (write)                                       │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ list_commits        │ GET         │ repo for private                                   │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ get_file_contents   │ GET         │ repo for private                                   │
#  ├─────────────────────┼─────────────┼────────────────────────────────────────────────────┤
#  │ search_code         │ GET         │ repo (code search requires this for private repos) │
#  └─────────────────────┴─────────────┴────────────────────────────────────────────────────┘
GITHUB_TOKEN=ghp_your_github_personal_access_token_here

# PostgreSQL connector (REQUIRED to use PostgreSQL tools)
PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=your_database_name
PG_USER=your_database_user
PG_PASSWORD=your_database_password
PG_SSL=false
PG_READ_ONLY=true

# -----------------------------------------------------------------------------
# Database DSNs (SQLite for single-server, PostgreSQL for scale)
# All default to in-memory if not set. For production, use file paths.
# Format: sqlite:////absolute/path/to/file.db
# -----------------------------------------------------------------------------

BILLING_DSN=sqlite:////var/lib/a2a/billing.db
PAYWALL_DSN=sqlite:////var/lib/a2a/paywall.db
PAYMENTS_DSN=sqlite:////var/lib/a2a/payments.db
MARKETPLACE_DSN=sqlite:////var/lib/a2a/marketplace.db
TRUST_DSN=sqlite:////var/lib/a2a/trust.db
EVENT_BUS_DSN=sqlite:////var/lib/a2a/events.db
WEBHOOK_DSN=sqlite:////var/lib/a2a/webhooks.db
IDENTITY_DSN=sqlite:////var/lib/a2a/identity.db
MESSAGING_DSN=sqlite:////var/lib/a2a/messaging.db
DISPUTE_DSN=sqlite:////var/lib/a2a/disputes.db

# Legacy aliases (older config files may use these)
# BILLING_DB=sqlite:///data/billing.db
# TRUST_DB=sqlite:///data/trust.db
# PAYWALL_DB=sqlite:///data/paywall.db
# MARKETPLACE_DB=sqlite:///data/marketplace.db
# PAYMENTS_DB=sqlite:///data/payments.db
# REPUTATION_DB=sqlite:///data/reputation.db

# -----------------------------------------------------------------------------
# Paywall / Tier Configuration
# Override defaults if needed
# -----------------------------------------------------------------------------

# Default tier for new agents (free, pro, enterprise)
DEFAULT_TIER=free

# -----------------------------------------------------------------------------
# Reputation Pipeline
# -----------------------------------------------------------------------------

# How often to run probe cycles (seconds)
PROBE_INTERVAL=300

# How often to run security scans (seconds)
SCAN_INTERVAL=3600

# Pipeline cycle interval (seconds)
PIPELINE_CYCLE=60

# HTTP timeout for probes (seconds)
PROBE_TIMEOUT=10

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------

# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
