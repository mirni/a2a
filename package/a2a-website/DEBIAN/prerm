#!/bin/bash
set -e

case "$1" in
    remove|deconfigure)
        # Disable website nginx site
        rm -f /etc/nginx/sites-enabled/website
        nginx -t 2>/dev/null && systemctl reload nginx 2>/dev/null || true
        ;;
    upgrade|failed-upgrade)
        ;;
    *)
        echo "prerm called with unknown argument '$1'" >&2
        exit 1
        ;;
esac

exit 0
